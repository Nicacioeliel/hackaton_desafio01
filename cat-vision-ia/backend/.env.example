# Banco: SQLite (MVP) ou PostgreSQL
DATABASE_URL=sqlite:///./data/catvision.db

# Para PostgreSQL (docker-compose):
# DATABASE_URL=postgresql+psycopg://catvision:catvision@localhost:5432/catvision

APP_NAME=CAT Vision IA
DEBUG=true
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Armazenamento de uploads (relativo ao cwd do backend)
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=25

# BrasilAPI
BRASIL_API_BASE=https://brasilapi.com.br/api
CNPJ_REQUEST_TIMEOUT_SECONDS=8

# OCR
OCR_PRIMARY=auto
# auto | pymupdf | tesseract | docling
USE_DOCLING=false
TESSERACT_CMD=

# LGPD / logs
MASK_LOGS=true
LOG_LEVEL=INFO
